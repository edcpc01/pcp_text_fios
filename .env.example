# Firebase Config — copie para .env.local e preencha com seus valores
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=pcptextfios.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pcptextfios
VITE_FIREBASE_STORAGE_BUCKET=pcptextfios.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=your_app_id_here

# Gemini API — obtenha em https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
