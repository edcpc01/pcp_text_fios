rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Qualquer usuário autenticado pode ler e escrever planning e production
    // Regras mais restritivas podem ser adicionadas depois
    match /planning_entries/{docId} {
      allow read, write: if request.auth != null;
    }

    match /production_records/{docId} {
      allow read, write: if request.auth != null;
    }

    match /agent_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Users — qualquer autenticado pode ler e criar o próprio documento
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // KPIs diários — leitura livre para autenticados
    match /kpis_daily/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
