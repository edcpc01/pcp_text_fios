{
  "env": {
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "extends": [
    "eslint:recommended",
    "google"
  ],
  "rules": {
    "no-restricted-globals": ["error", "name", "length"],
    "prefer-arrow-callback": "error",
    "quotes": ["error", "single", { "avoidEscape": true }],
    "max-len": ["warn", { "code": 120 }],
    "indent": ["error", 2],
    "require-jsdoc": "off",
    "valid-jsdoc": "off"
  },
  "overrides": [
    {
      "files": ["**/*.spec.*"],
      "env": { "mocha": true },
      "rules": {}
    }
  ],
  "root": true
}
